@model WebApplication1.Models.Student

<h2>Add Student</h2>

<form asp-action="Create" method="post">
    <div>
        <label>Name:</label>
        <input asp-for="name" />
    </div>
    <div>
        <label>Age:</label>
        <input asp-for="age" type="number" />
    </div>
    <div>
        <label>Email:</label>
        <input asp-for="email" type="email" />
    </div>
    <button type="submit">Save</button>
</form>
<a href="@Url.Action("Index", "Student")">Back to List</a>
