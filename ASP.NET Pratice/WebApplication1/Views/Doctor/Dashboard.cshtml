@using System.Data
@using Microsoft.AspNetCore.Http
@inject IHttpContextAccessor HttpContextAccessor
@model DataTable

@{
    ViewData["Title"] = "Doctor Dashboard";

    // 1. Get basic session info
    string doctorSessionName = HttpContextAccessor.HttpContext.Session.GetString("DoctorName");

    // 2. Initialize variables with default values to prevent null errors
    string currentFullName = doctorSessionName;
    string currentEmail = "";
    string currentSpecialization = "";
    string currentAvailability = "";
    string currentProfile = "";

    // 3. Load data from the Model (Data fetched from JOIN query in Controller)
    if (Model != null && Model.Rows.Count > 0)
    {
        // These column names must match your SQL SELECT statement exactly
        currentFullName = Model.Rows[0]["FullName"].ToString();
        currentEmail = Model.Rows[0]["Email"].ToString();
        currentSpecialization = Model.Rows[0]["Specialization"].ToString();
        currentAvailability = Model.Rows[0]["Availability"].ToString();
        currentProfile = Model.Rows[0]["ProfileDetails"].ToString();
    }
}

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />

<div class="container mt-4">
    <div class="row">
        <div class="col-md-12">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <h2 class="text-primary fw-bold mb-0">Welcome, Dr. @currentFullName</h2>
                    <p class="text-muted small"><i class="fas fa-hospital-user me-2"></i>Hospital Management System | Doctor Panel</p>
                </div>
                <div class="text-end">
                    <span class="badge bg-light text-primary border p-2">
                        <i class="fas fa-calendar-day me-1"></i> @DateTime.Now.ToString("dd MMM yyyy")
                    </span>
                </div>
            </div>
            <hr />

            @if (TempData["Message"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show border-0 shadow-sm" role="alert">
                    <i class="fas fa-check-circle me-2"></i> @TempData["Message"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }
        </div>
    </div>

    <div class="row mb-4 g-3">
        <div class="col-md-4">
            <div class="card bg-primary text-white shadow-sm border-0 h-100">
                <div class="card-body d-flex flex-column justify-content-center py-4">
                    <h5 class="card-title opacity-75 fw-bold small text-uppercase">Total Appointments</h5>
                    <div class="d-flex align-items-center">
                        <h1 class="display-4 fw-bold mb-0">@ViewBag.TotalAppointments</h1>
                        <i class="fas fa-calendar-check fa-3x ms-auto opacity-25"></i>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-8">
            <div class="card shadow-sm border-0 h-100">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <h5 class="card-title fw-bold text-dark mb-0">Filter Schedule</h5>
                        <a asp-action="Dashboard" class="small text-decoration-none fw-bold">Show All Records</a>
                    </div>
                    <form asp-action="Dashboard" method="get" class="row g-2">
                        <div class="col-sm-9">
                            <input type="date" name="searchDate" class="form-control" value="@ViewBag.SelectedDate" />
                        </div>
                        <div class="col-sm-3">
                            <button type="submit" class="btn btn-primary w-100 fw-bold">Filter</button>
                        </div>
                    </form>
                    <p class="small text-muted mt-2 mb-0">Viewing: <strong>@ViewBag.SelectedDate</strong></p>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-md-5">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-dark text-white fw-bold py-3">
                    <i class="fas fa-user-edit me-2"></i>Update My Details
                </div>
                <div class="card-body">
                    <form asp-action="UpdateProfile" method="post">
                        <div class="mb-3">
                            <label class="form-label small fw-bold text-uppercase">Full Name</label>
                            <input name="FullName" class="form-control border-primary" value="@currentFullName" required />
                        </div>
                        <div class="mb-3">
                            <label class="form-label small fw-bold text-uppercase">Email Address</label>
                            <input name="Email" type="email" class="form-control border-primary" value="@currentEmail" required />
                        </div>
                        <hr />
                        <div class="mb-3">
                            <label class="form-label small fw-bold text-uppercase">Specialization</label>
                            <input name="Specialization" class="form-control bg-light border-0" value="@currentSpecialization" required />
                        </div>
                        <div class="mb-3">
                            <label class="form-label small fw-bold text-uppercase">Availability (Days/Time)</label>
                            <input name="Availability" class="form-control bg-light border-0" value="@currentAvailability" required />
                        </div>
                        <div class="mb-3">
                            <label class="form-label small fw-bold text-uppercase">Profile Details</label>
                            <textarea name="ProfileDetails" class="form-control bg-light border-0" rows="3">@currentProfile</textarea>
                        </div>
                        <button type="submit" class="btn btn-success w-100 fw-bold py-2 shadow-sm">
                            <i class="fas fa-save me-2"></i>Apply Changes
                        </button>
                    </form>
                </div>
            </div>
        </div>

        <div class="col-md-7">
            <div class="card shadow-sm border-0 h-100">
                <div class="card-header bg-secondary text-white fw-bold py-3">
                    <i class="fas fa-clipboard-list me-2"></i>Patient Schedule
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th class="ps-3 fw-bold small text-uppercase">Patient Name</th>
                                    <th class="fw-bold small text-uppercase">Date & Time</th>
                                    <th class="text-center fw-bold small text-uppercase">Status</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (ViewBag.DateWisePatients != null && ((DataTable)ViewBag.DateWisePatients).Rows.Count > 0)
                                {
                                    foreach (DataRow row in ((DataTable)ViewBag.DateWisePatients).Rows)
                                    {
                                        <tr>
                                            <td class="ps-3 fw-bold">@row["FullName"]</td>
                                            <td>
                                                <div class="small fw-bold text-dark">@Convert.ToDateTime(row["AppointmentDate"]).ToString("dd MMM yyyy")</div>
                                                <div class="small text-muted">@row["AppointmentTime"]</div>
                                            </td>
                                            <td class="text-center">
                                                <span class="badge rounded-pill bg-warning text-dark px-3 fw-normal">@row["Status"]</span>
                                            </td>
                                        </tr>
                                    }
                                }
                                else
                                {
                                    <tr>
                                        <td colspan="3" class="text-center py-5 text-muted">
                                            <i class="fas fa-calendar-times fa-3x mb-3 d-block opacity-25"></i>
                                            No appointments found.
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .bg-soft-primary {
        background-color: #e3f2fd;
    }

    .card {
        transition: transform 0.2s;
    }

    .table th {
        border-top: none;
    }
</style>